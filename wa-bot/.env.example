# ── 必填 ────────────────────────────────────────────────────────────────────────

# Gemini API Key（收据 OCR 识别）
GEMINI_API_KEY=your_gemini_api_key_here

# Session 签名密钥（必填，防止重启后 cookie 签名失效导致所有用户被踢出）
# 生成命令：openssl rand -hex 32
SESSION_SECRET=your_random_secret_here

# ── 可选 ────────────────────────────────────────────────────────────────────────

# 数据目录（默认：项目根目录的 data/，容器内由 docker-compose 注入）
# DATA_DIR=/app/data
